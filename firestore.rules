rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'topics', 'joinedAt'])
        && data.keys().size() == 6
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.role == 'member'
        && data.topics is list
        && data.name is string && data.name.size() <= 100
        && data.joinedAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['type', 'author', 'authorId', 'category', 'content', 'likes', 'commentCount', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.type in ['discussion', 'research', 'question']
        && data.category in ['Finance', 'Economics', 'Business', 'Policy', 'Other']
        && data.likes is int && data.likes >= 0
        && data.commentCount is int && data.commentCount >= 0
        && data.content is string && data.content.size() <= 1000000
        && data.createdAt == request.time
        // Optional fields
        && (!data.keys().contains('title') || (data.title is string && data.title.size() <= 200))
        && (!data.keys().contains('abstract') || (data.abstract is string && data.abstract.size() <= 5000))
        && (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && (!data.keys().contains('pdfUrl') || (data.pdfUrl is string && data.pdfUrl.size() <= 1000));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'text', 'likes', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.text is string && data.text.size() <= 50000
        && data.likes is int && data.likes >= 0
        && data.createdAt == request.time;
    }

    function isValidManuscript(data) {
      return data.keys().hasAll(['name', 'institution', 'email', 'content', 'pdfUrl', 'status', 'submittedAt'])
        && data.name is string && data.name.size() <= 100
        && data.institution is string && data.institution.size() <= 200
        && data.email is string && data.email.size() <= 100
        && data.content is string && data.content.size() <= 1000000
        && data.pdfUrl is string && data.pdfUrl.size() <= 1000
        && data.status == 'pending'
        && data.submittedAt == request.time;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'dateTime', 'location', 'description', 'category', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.location is string && data.location.size() <= 500
        && data.description is string && data.description.size() <= 2000
        && data.category is string
        && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // RULES
    // -------------------------------------------------------------------------

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'topics', 'joinedAt'])
        && (incoming().joinedAt == existing().joinedAt) // Prevent changing join date
        && incoming().name is string && incoming().name.size() <= 100
        && incoming().topics is list;
    }

    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if (isVerified() && isValidPost(incoming())) || (isSignedIn() && incoming().seeded == true) || (isAdmin() && isValidPost(incoming())); 
      allow update: if (isSignedIn() && (
        // Like Action
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && (incoming().likes == existing().likes + 1 || incoming().likes == existing().likes - 1)) ||
        // Comment Count Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']))
      )) || isAdmin();
      allow delete: if isAdmin();

      // Comments Subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isVerified() && isValidComment(incoming());
        allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) || isAdmin();
        allow delete: if isAdmin();
      }

      // Likes tracking
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) && isValidId(userId);
      }
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Publications
    match /publications/{pubId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Manuscripts (Submissions)
    match /manuscripts/{manId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidManuscript(incoming());
      allow update, delete: if isAdmin();
    }

    // Rigor Content
    match /rigor_content/{rigorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meta
    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && docId == 'seeded'); 
    }

  }
}
