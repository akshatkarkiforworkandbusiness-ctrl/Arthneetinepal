rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'topics', 'joinedAt'])
        && data.keys().hasOnly(['uid', 'name', 'email', 'role', 'topics', 'joinedAt', 'schoolId', 'publicPortfolio'])
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.role == 'member'
        && data.topics is list
        && data.name is string && data.name.size() <= 100
        && data.joinedAt == request.time
        && (!('schoolId' in data) || (data.schoolId is string && data.schoolId.size() <= 100))
        && (!('publicPortfolio' in data) || data.publicPortfolio is bool);
    }

    function isValidProgress(data) {
      return data.keys().hasOnly(['completed', 'quizScores', 'masterExamScores', 'badges', 'updatedAt'])
        && (!('completed' in data) || (data.completed is list && data.completed.size() <= 200))
        && (!('badges' in data) || (data.badges is list && data.badges.size() <= 50
             && data.badges.hasOnly(['First Steps', 'Quiz Whiz', 'Financial Literacy Master', 'Market Maestro'])))
        && (!('quizScores' in data) || data.quizScores is map)
        && (!('masterExamScores' in data) || data.masterExamScores is map)
        && data.updatedAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['type', 'author', 'authorId', 'category', 'content', 'likes', 'commentCount', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.type in ['discussion', 'research', 'question', 'trade-recap']
        && data.category in ['Finance', 'Economics', 'Business', 'Policy', 'Other']
        && data.likes is int && data.likes >= 0
        && data.commentCount is int && data.commentCount >= 0
        && data.content is string && data.content.size() <= 1000000
        && data.createdAt == request.time
        && (!('title' in data) || (data.title is string && data.title.size() <= 200))
        && (!('abstract' in data) || (data.abstract is string && data.abstract.size() <= 5000))
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && (!('pdfUrl' in data) || (data.pdfUrl is string && data.pdfUrl.size() <= 1000));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'text', 'likes', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.text is string && data.text.size() <= 50000
        && data.likes is int && data.likes >= 0
        && data.createdAt == request.time;
    }

    function isValidManuscript(data) {
      return data.keys().hasAll(['name', 'institution', 'email', 'content', 'pdfUrl', 'status', 'submittedAt'])
        && data.name is string && data.name.size() <= 100
        && data.institution is string && data.institution.size() <= 200
        && data.email is string && data.email.size() <= 100
        && data.content is string && data.content.size() <= 1000000
        && data.pdfUrl is string && data.pdfUrl.size() <= 1000
        && data.status == 'pending'
        && data.submittedAt == request.time;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'dateTime', 'location', 'description', 'category', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.location is string && data.location.size() <= 500
        && data.description is string && data.description.size() <= 2000
        && data.category is string
        && data.createdAt == request.time;
    }

    function isValidCertificate(data) {
      return data.keys().hasOnly(['uid', 'name', 'moduleId', 'moduleTitle', 'score', 'completedAt', 'topPerformer'])
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.moduleId is string && data.moduleId.size() <= 100
        && data.moduleTitle is string && data.moduleTitle.size() <= 200
        && data.score is number && data.score >= 0 && data.score <= 100
        && data.completedAt == request.time
        && (!('topPerformer' in data) || data.topPerformer is bool);
    }

    // -------------------------------------------------------------------------
    // RULES
    // -------------------------------------------------------------------------

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins
    match /admins/{userId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'topics', 'joinedAt', 'publicPortfolio'])
        && (incoming().joinedAt == existing().joinedAt)
        && incoming().name is string && incoming().name.size() <= 100
        && incoming().topics is list
        && (!('publicPortfolio' in incoming()) || incoming().publicPortfolio is bool);

      // Learning progress subcollection
      match /progress/{docId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) && isValidProgress(incoming());
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if (isVerified() && isValidPost(incoming())) || (isSignedIn() && incoming().seeded == true) || (isAdmin() && isValidPost(incoming()));
      allow update: if (isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && (incoming().likes == existing().likes + 1 || incoming().likes == existing().likes - 1)) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']))
      )) || (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'abstract', 'category', 'updatedAt']) && request.time < existing().createdAt + duration.value(24, 'h')) || isAdmin();
      
      allow delete: if (isOwner(existing().authorId) && existing().commentCount == 0) || isAdmin();

      // Comments Subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isVerified() && isValidComment(incoming());
        allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) || isAdmin();
        allow delete: if isAdmin();
      }

      // Likes tracking
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) && isValidId(userId);
      }
    }

    // Lesson Comments
    match /lessons/{lessonId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && (
        isValidEvent(incoming())
        || incoming().diff(existing()).affectedKeys().hasOnly(['imageUrl', 'completed', 'studentsReached'])
      );
      allow delete: if isAdmin();
    }

    // Publications
    match /publications/{pubId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Manuscripts (Submissions)
    match /manuscripts/{manId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidManuscript(incoming());
      allow update, delete: if isAdmin();
    }

    // Rigor Content
    match /rigor_content/{rigorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meta
    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && docId == 'seeded');
    }

    // Portfolios
    match /portfolios/{userId} {
      allow read: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.publicPortfolio == true);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['cashBalance', 'holdings', 'totalValue', 'updatedAt'])
        && request.resource.data.cashBalance is number && request.resource.data.cashBalance >= 0;
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['cashBalance', 'holdings', 'totalValue', 'updatedAt'])
        && request.resource.data.cashBalance is number && request.resource.data.cashBalance >= 0;
      allow delete: if false;

      match /trades/{tradeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['symbol', 'side', 'quantity', 'price', 'total', 'timestamp'])
          && request.resource.data.quantity is number && request.resource.data.quantity > 0;
        allow update, delete: if false; // trade history is append-only
      }
    }

    // Leaderboards
    match /leaderboards/{snapshotId} {
      allow read: if true;
      allow write: if false;
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Certificates
    match /certificates/{certId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == certId.split('_')[0] && isValidCertificate(incoming());
      allow delete: if isAdmin();
    }

  }
}
